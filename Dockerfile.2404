# =============================================================================
# Stage 1: builder — ubuntu:24.04 + Python 3.12 (system default)
#
# Builds opencv-python-headless from PR #1190, which removes the custom
# OpenSSL 1.1.1w bundled into the wheel and uses the system OpenSSL instead.
# On a FIPS-enforced host the system OpenSSL is FIPS-certified, so no more
# "FATAL FIPS SELFTEST FAILURE" when importing cv2.
#
# --copies venv: real binaries (no symlinks) so COPY --from works in distroless.
# =============================================================================
FROM ubuntu:24.04 AS builder

ENV DEBIAN_FRONTEND=noninteractive \
    ENABLE_HEADLESS=1 \
    CMAKE_BUILD_PARALLEL_LEVEL=4

# Python 3.12 is the system default in Ubuntu 24.04 — no deadsnakes needed
RUN apt-get update && apt-get install -y --no-install-recommends \
        python3.12 python3.12-dev python3.12-venv \
        git curl ca-certificates \
        cmake ninja-build \
        gcc g++ \
        libglib2.0-dev \
        libssl-dev \
    && rm -rf /var/lib/apt/lists/*

# Create venv first — avoids PEP 668 (Ubuntu 24.04 blocks pip outside venv)
# --copies: real binaries instead of symlinks, required for distroless COPY
RUN python3.12 -m venv --copies /opt/venv

# Build-time deps matching pyproject.toml scikit-build backend
RUN /opt/venv/bin/pip install --no-cache-dir \
        scikit-build numpy setuptools packaging pip wheel

# Fetch opencv-python at PR #1190 (commit a068215:
# "manylinux: avoid bundling OpenSSL to fix FIPS import crash")
WORKDIR /build
RUN git clone --depth 100 https://github.com/opencv/opencv-python.git \
    && cd opencv-python \
    && git fetch origin pull/1190/head:pr-1190 \
    && git checkout pr-1190

RUN cd /build/opencv-python \
    && /opt/venv/bin/pip wheel . --no-build-isolation -w /wheels

RUN /opt/venv/bin/pip install --no-cache-dir /wheels/opencv_python_headless*.whl \
    && /opt/venv/bin/pip install --no-cache-dir fast-alpr

# =============================================================================
# Stage 2: fips-config — debian:trixie-slim
#
# Must match the OS of the final stage (distroless/base-debian13 = trixie)
# so that fips.so is ABI-compatible with libcrypto.so.3 at runtime.
#
# Same approach as bookworm: fips.so is not shipped in the standard openssl
# package, so we build it from the matching GitHub tag.
#
# fipsmodule.cnf contains an HMAC of fips.so — both must be copied together
# to the final stage so the integrity check passes.
# =============================================================================
FROM debian:trixie-slim AS fips-config

RUN apt-get update && apt-get install -y --no-install-recommends \
        openssl build-essential git ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# Detect installed OpenSSL version → clone matching tag → build only fips.so
RUN OPENSSL_VERSION=$(openssl version | awk '{print $2}') \
    && echo "Building OpenSSL fips.so for version: ${OPENSSL_VERSION}" \
    && git clone --depth 1 \
        --branch openssl-${OPENSSL_VERSION} \
        https://github.com/openssl/openssl.git /tmp/openssl-src \
    && cd /tmp/openssl-src \
    && ./Configure enable-fips \
        --prefix=/usr \
        --openssldir=/usr/lib/ssl \
        --libdir=lib/x86_64-linux-gnu \
    && make -j$(nproc) \
    && make install_fips \
    && rm -rf /tmp/openssl-src

RUN openssl fipsinstall \
        -module /usr/lib/x86_64-linux-gnu/ossl-modules/fips.so \
        -out /etc/ssl/fipsmodule.cnf

RUN cat > /etc/ssl/openssl-fips.cnf <<'EOF'
config_diagnostics = 1
openssl_conf = openssl_init

.include /etc/ssl/fipsmodule.cnf

[openssl_init]
providers = provider_sect

[provider_sect]
fips = fips_sect
base = base_sect

[base_sect]
activate = 1
EOF

# =============================================================================
# Stage 3: final — distroless/base-debian13
#
# Copies /opt/venv (--copies = self-contained), libpython3.12.so, and the
# matched fips.so + fipsmodule.cnf from the trixie fips-config stage.
# libssl3/libcrypto are already present in distroless/base-debian13.
# =============================================================================
FROM gcr.io/distroless/base-debian13

COPY --from=builder /opt/venv                                        /opt/venv
COPY --from=builder /usr/lib/python3.12                              /usr/lib/python3.12
COPY --from=builder /usr/lib/x86_64-linux-gnu/libpython3.12.so.1.0  /usr/lib/x86_64-linux-gnu/libpython3.12.so.1.0

# Matched pair — fips.so and fipsmodule.cnf must come from the same stage
COPY --from=fips-config /usr/lib/x86_64-linux-gnu/ossl-modules/fips.so  /usr/lib/x86_64-linux-gnu/ossl-modules/fips.so
COPY --from=fips-config /etc/ssl/fipsmodule.cnf                          /etc/ssl/fipsmodule.cnf
COPY --from=fips-config /etc/ssl/openssl-fips.cnf                        /etc/ssl/openssl-fips.cnf

ENV PATH="/opt/venv/bin:$PATH" \
    PYTHONPATH="/opt/venv/lib/python3.12/site-packages" \
    OPENSSL_CONF=/etc/ssl/openssl-fips.cnf \
    OPENSSL_MODULES=/usr/lib/x86_64-linux-gnu/ossl-modules

ENTRYPOINT ["/opt/venv/bin/python3"]
